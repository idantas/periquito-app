{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri-schema/refs/heads/main/tauri.conf.schema.json",
  "productName": "Periquito",
  "version": "1.0.0",
  "identifier": "com.lucianfialho.periquito",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Periquito",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": true,
        "width": 500,
        "height": 500,
        "x": 0,
        "y": 0
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/*"],
    "macOS": {
      "minimumSystemVersion": "14.0"
    }
  },
  "plugins": {}
}
